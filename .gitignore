# Local config & secrets
# config.yaml and config_template.yaml both embed live API keys -> never commit.
# `novel.py create` copies config_template.yaml locally, so it must exist on disk
# but stays out of git.
config.yaml
config_template.yaml
novels/*/config.yaml
# Per-endpoint screenplay configs also embed live API keys (e.g. config_script_gpt55.yaml).
config_*.yaml
.env
.env.*

# Databases
*.db
*.db-shm
*.db-wal

# Backups & scratch
*.bak
state.md.bak
_repair_backup/
_smoke_pipeline/
*_stdout*.log
*_stderr*.log
_check_keys_*.txt

# Generated outputs — root legacy long novel
book.md
state.md
chapters/
memory/
book_refined.md
chapters_refined/

# Generated outputs — per-novel directories (keep prompt.md, drop the rest)
novels/*/book.md
novels/*/state.md
novels/*/book_refined.md
novels/*/chapters/
novels/*/chapters_refined/
novels/*/memory/
novels/*/logs/
novels/*/scripts/
novels/

# Screenplay conversion outputs & checkpoints (standalone --input mode writes a
# scripts/ dir next to the input file; checkpoints are resumable scratch state).
scripts/
*.md.checkpoints/

# One-off scripts
check_token_plan_keys.py
repair_stub_chapters.py

# Scratch / debugging artifacts
*.broken
screenplay_head.txt
screenplay_tail.txt

# OS
.DS_Store
Thumbs.db
desktop.ini
